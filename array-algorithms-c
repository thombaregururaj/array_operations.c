#include <stdio.h>

int main() {
    int arr[100], n, i;
    int sum = 0, largest, smallest;

    printf("Enter number of elements: ");
    scanf("%d", &n);

    printf("Enter %d elements:\n", n);
    for(i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    largest = smallest = arr[0];

    for(i = 0; i < n; i++) {
        sum += arr[i];

        if(arr[i] > largest)
            largest = arr[i];

        if(arr[i] < smallest)
            smallest = arr[i];
    }

    printf("\nArray Elements: ");
    for(i = 0; i < n; i++) {
        printf("%d ", arr[i]);
    }

    printf("\nSum = %d", sum);
    printf("\nLargest Element = %d", largest);
    printf("\nSmallest Element = %d", smallest);

    return 0;
}